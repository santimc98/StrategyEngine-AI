# ============================================================================
# StrategyEngine AI - Variables de Entorno
# ============================================================================
#
# Bootstrap tecnico minimo.
# La configuracion operativa real se gestiona desde la UI:
#   - API keys   -> store cifrado local
#   - modelos    -> configuracion persistida del runtime
#   - sandbox    -> configuracion persistida del sandbox
#
# Este archivo debe quedarse como fallback/bootstrap, no como fuente de verdad
# para empresas en produccion.
# ============================================================================


# --- Runtime ----------------------------------------------------------------
OPENROUTER_TIMEOUT_SECONDS=120
RUN_EXECUTION_MODE=local


# --- Rutas de almacenamiento ------------------------------------------------
# El sistema resuelve todas las rutas desde src/utils/paths.py.
# Por defecto se auto-detectan relativas al directorio del proyecto.
# En despliegues enterprise se pueden sobreescribir para apuntar a
# volumenes externos, NAS, NFS, EFS, GCS FUSE, etc.
#
# PROJECT_ROOT=/app
# RUNS_DIR=/mnt/shared/strategyengine/runs
# DATA_DIR=/mnt/shared/strategyengine/data


# --- Docker Compose (solo aplica al docker-compose.yml) ---------------------
# Volumenes host que se montan en el contenedor.
# Util cuando el almacenamiento esta en un mount point externo.
#
# RUNS_VOLUME=/mnt/nas/strategyengine/runs
# DATA_VOLUME=/mnt/nas/strategyengine/data


# --- API Keys (fallback) ---------------------------------------------------
# En un despliegue comercial normal, estos valores se configuran desde la UI.
#
# GOOGLE_API_KEY=your_google_key
# OPENROUTER_API_KEY=your_openrouter_key
